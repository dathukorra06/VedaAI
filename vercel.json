{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/next"
    },
    {
      "src": "backend/src/server.ts",
      "use": "@vercel/node"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "dest": "backend/src/server.ts"
    },
    {
      "source": "/(.*)",
      "dest": "frontend/$1"
    }
  ],
  "env": {
    "NEXT_PUBLIC_API_URL": "https://veda-ai-backend.vercel.app",
    "FRONTEND_URL": "https://veda-ai-frontend-theta.vercel.app"
  }
}
